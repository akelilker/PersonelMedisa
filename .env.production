# Uretim build: gercek host / CDN URL'lerini CI veya sunucuda set edin.
# Domain kokunde yayin icin "/" kullanilir. Alt klasor gerekiyorsa or. "/personelmedisa/" verilir.
VITE_APP_BASE_PATH=/

VITE_API_BASE_URL=
VITE_API_MODE=auto
VITE_DEMO_API_FALLBACK=true
VITE_REALTIME_WS_URL=
VITE_APP_ENV=production
VITE_APP_VERSION=0.1.0
VITE_ENABLE_DIAGNOSTICS=false
