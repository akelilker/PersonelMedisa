# Üretim build: gerçek host / CDN URL'lerini CI veya sunucuda set edin.
# Alt klasörde yayın için mutlaka / ile bitirin; aksi halde JS/CSS yolu kırılır.
VITE_APP_BASE_PATH=/personelmedisa/

VITE_API_BASE_URL=
VITE_API_MODE=real
VITE_DEMO_API_FALLBACK=false
VITE_REALTIME_WS_URL=
VITE_APP_ENV=production
VITE_APP_VERSION=0.1.0
VITE_ENABLE_DIAGNOSTICS=false
