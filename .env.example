# Kopyalayıp .env.local, .env.development veya ortama göre .env dosyası oluşturun.
# Asla gerçek şifre, token veya gizli anahtar commit etmeyin.

# Üretim: site alt klasörde ise / ile bitirin (ör. /personelmedisa/). Boş veya ./ = kök dizin.
VITE_APP_BASE_PATH=

VITE_API_BASE_URL=
# real | demo | mock | auto
# Üretimde önerilen değer: real
VITE_API_MODE=auto
# Üretimde mutlaka false olmalı; demo fallback canlı API hatalarını maskeleyebilir.
VITE_DEMO_API_FALLBACK=true

VITE_REALTIME_WS_URL=

# production | development | veya özelleştirilmiş etiket
VITE_APP_ENV=development

# Sürüm etiketi (deploy / hata ayıklama); boş ise 0.1.0 fallback
VITE_APP_VERSION=0.1.0

# Üretimde true yapılırsa /internal/diagnostics açılır (varsayılan kapalı)
VITE_ENABLE_DIAGNOSTICS=false
