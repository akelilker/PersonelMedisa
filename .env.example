# Kopyalayip .env.local veya ortama gore .env dosyasi olusturun.
# Asla gercek sifre/token commit etmeyin.

# Uretim: site alt klasorde ise / ile bitirin (or. /personelmedisa/). Bos veya ./ = kok dizin.
VITE_APP_BASE_PATH=

VITE_API_BASE_URL=
# real | demo | mock | auto
VITE_API_MODE=auto
VITE_DEMO_API_FALLBACK=true

VITE_REALTIME_WS_URL=

# production | development | veya ozellestirilmis etiket
VITE_APP_ENV=development

# Surum etiketi (deploy / hata ayiklama); bos ise 0.1.0 fallback
VITE_APP_VERSION=0.1.0

# Uretimde true yapilirsa /internal/diagnostics acilir (varsayilan kapali)
VITE_ENABLE_DIAGNOSTICS=false
